# SMART JEWELLERY INVENTORY OS - Environment Variables

# Supabase Configuration
# Get these from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenRouter API (for AI image analysis)
# Get this from: https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-your-api-key-here

# Note: Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to GitHub!